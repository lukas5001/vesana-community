# Copy to .env and fill in real values. NEVER commit a real .env.

# Database (prod: existing shared Postgres + the "community" schema)
DATABASE_URL=postgresql+psycopg://community:community@localhost:5432/community

# Signs the session cookie AND the HS256 API tokens. Use a long random value.
SECRET_KEY=change-me-to-a-long-random-secret

# Portal Ed25519 PUBLIC key — the trust anchor for login JWTs.
# Provide EITHER the inline PEM ...
# PORTAL_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ... OR a path to a PEM file:
PORTAL_PUBLIC_KEY_PATH=/run/secrets/portal_public_key.pem

# Token lifetimes
API_TOKEN_TTL_DAYS=30
LOGIN_TOKEN_LEEWAY_SECONDS=30

# Admin HTTP Basic auth
COMMUNITY_ADMIN_USER=admin
COMMUNITY_ADMIN_PASSWORD=change-me

# Public base URL of this app
COMMUNITY_BASE_URL=http://localhost:8080
